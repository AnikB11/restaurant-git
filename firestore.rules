// firestore.rules
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isStaff(restaurantId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/staff/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.restaurant_id == restaurantId;
    }

    function hasRole(role) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/staff/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role == role ||
         get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role == 'admin');
    }

    // ── Restaurants ───────────────────────────────────────────────────
    match /restaurants/{restaurantId} {
      allow read: if true; // Guests need to read restaurant info
      allow write: if hasRole('admin');
    }

    // ── Tables ────────────────────────────────────────────────────────
    match /tables/{tableId} {
      allow read: if true; // Guests resolve their token here
      allow write: if isAuthenticated();
    }

    // ── Menu Items ────────────────────────────────────────────────────
    match /menu_items/{itemId} {
      allow read: if true; // Guests need to browse menu
      allow create, delete: if hasRole('admin');
      allow update: if isAuthenticated(); // Kitchen staff can toggle availability
    }

    // ── Orders ────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Guests can create orders (no auth), staff can read/update all
      allow create: if true;
      allow read: if true; // Guests need to track their orders by ID
      allow update: if true; // Guests update bill_requested/staff_called; staff update status
      allow delete: if hasRole('admin');
    }

    // ── Staff ─────────────────────────────────────────────────────────
    match /staff/{staffId} {
      allow read: if request.auth.uid == staffId || hasRole('admin');
      allow write: if hasRole('admin');
    }
  }
}
